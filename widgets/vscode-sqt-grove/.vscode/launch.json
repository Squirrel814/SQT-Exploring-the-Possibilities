{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run SQT Grove Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/**/*.js"
      ],
      "cwd": "${workspaceFolder}/../.."
    }
  ]
}